{
  "title": "RDWS Gateway — Overview",
  "uid": "rdws-gateway-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Healthy Services / total",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rdws-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rdws_gateway_services_healthy",
          "legendFormat": "healthy"
        },
        {
          "refId": "B",
          "expr": "rdws_gateway_services_total",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active Connections / Pending Requests",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "rdws-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rdws_gateway_active_connections",
          "legendFormat": "active_connections"
        },
        {
          "refId": "B",
          "expr": "rdws_gateway_pending_requests",
          "legendFormat": "pending_requests"
        }
      ]
    },
    {
      "id": 3,
      "title": "Requests per Capability (rate/5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "rdws-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(rdws_gateway_requests_total[5m])",
          "legendFormat": "{{capability}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Errors per Capability (rate/5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "rdws-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(rdws_gateway_errors_total[5m])",
          "legendFormat": "{{capability}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Average Latency per Capability (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "rdws-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rdws_gateway_latency_avg_ms",
          "legendFormat": "{{capability}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "loki", "uid": "rdws-loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "{env=~\".+\"}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Requests per Capability (history, PersistenceService)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "postgres", "uid": "rdws-persistence" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT window_start AS time, capability, request_count FROM capability_metrics WHERE $__timeFilter(window_start) ORDER BY window_start",
          "rawQuery": true
        }
      ]
    },
    {
      "id": 8,
      "title": "Avg / p99 Latency per Capability (ms, history)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "postgres", "uid": "rdws-persistence" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT window_start AS time, capability || ' avg' AS metric, avg_latency_ms AS value FROM capability_metrics WHERE $__timeFilter(window_start) ORDER BY window_start",
          "rawQuery": true
        },
        {
          "refId": "B",
          "format": "time_series",
          "rawSql": "SELECT window_start AS time, capability || ' p99' AS metric, p99_latency_ms AS value FROM capability_metrics WHERE $__timeFilter(window_start) ORDER BY window_start",
          "rawQuery": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Recent Request History",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 40 },
      "datasource": { "type": "postgres", "uid": "rdws-persistence" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT recorded_at, request_id, capability, service_id, success, latency_ms FROM request_history WHERE $__timeFilter(recorded_at) ORDER BY recorded_at DESC LIMIT 200",
          "rawQuery": true
        }
      ]
    },
    {
      "id": 10,
      "title": "Sensor Readings (value over time)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 50 },
      "datasource": { "type": "postgres", "uid": "rdws-persistence" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT sr.timestamp AS time, 'sensor ' || sr.sensor_id || ' (' || s.type || ')' AS metric, sr.value::double precision AS value FROM sensor_readings sr JOIN sensors s ON s.id = sr.sensor_id WHERE $__timeFilter(sr.timestamp) ORDER BY sr.timestamp",
          "rawQuery": true
        }
      ]
    },
    {
      "id": 11,
      "title": "Recent Sensor Readings",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 58 },
      "datasource": { "type": "postgres", "uid": "rdws-persistence" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT sr.timestamp, sr.sensor_id, s.device_id, s.type AS sensor_type, s.unit, sr.value FROM sensor_readings sr JOIN sensors s ON s.id = sr.sensor_id WHERE $__timeFilter(sr.timestamp) ORDER BY sr.timestamp DESC LIMIT 200",
          "rawQuery": true
        }
      ]
    }
  ]
}
