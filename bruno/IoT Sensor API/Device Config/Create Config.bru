meta {
  name: Create Config
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/devices/1/config
  body: json
  auth: bearer
}

auth:bearer {
  token: {{jwtToken}}
}

body:json {
  {
    "config": {
      "sampleIntervalSec": 60,
      "transmitIntervalSec": 300,
      "alertThresholds": {
        "temperature": { "min": -5, "max": 45 },
        "humidity":    { "min": 10, "max": 95 }
      },
      "firmware": "v2.3.1"
    }
  }
}
