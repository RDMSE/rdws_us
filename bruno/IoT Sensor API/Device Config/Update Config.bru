meta {
  name: Update Config
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/devices/:devId/config
  body: json
  auth: bearer
}

params:path {
  devId: 14
}

auth:bearer {
  token: {{jwtToken}}
}

body:json {
  {
    "config": {
        "report_interval_s": 600,
        "sampling_interval_s": 10
      }
  }
}
