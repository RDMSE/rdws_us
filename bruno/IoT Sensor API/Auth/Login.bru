meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "{{adminUser}}",
    "password": "{{adminPass}}"
  }
}

script:post-response {
  if (res.status === 200 && res.body.data && res.body.data.token) {
    bru.setVar("jwtToken", res.body.data.token);
  }
}
