meta {
  name: Trigger Manual Send
  type: http
  seq: 1
}

post {
  url: {{simulatorBaseUrl}}:{{devicePort}}/simulate/:devId/trigger
  body: none
  auth: none
}

params:path {
  devId: {{devId}}
}

script:pre-request {
  const id = String(bru.getEnvVar("ID"));
  console.log("ID lido:", JSON.stringify(id));
  bru.setVar("devId", id);
  bru.setVar("devicePort", "91" + id.padStart(2, "0"));
  console.log("devId:", bru.getVar("devId"), "devicePort:", bru.getVar("devicePort"));
}
