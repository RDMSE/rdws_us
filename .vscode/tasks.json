{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake-build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build-debug",
                "--parallel"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "run-gateway",
            "type": "shell",
            "command": "${workspaceFolder}/build/src/service_broker/service_gateway_http",
            "args": [
                "8080",
                "3001",
                "/tmp/service_gateway.sock"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "cmake-build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "run-gateway (with persistence)",
            "type": "shell",
            "command": "${workspaceFolder}/build/src/service_broker/service_gateway_http",
            "args": [
                "8080",
                "3001",
                "/tmp/service_gateway.sock",
                "${workspaceFolder}/gateway.log",
                "${workspaceFolder}/routes.json"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "cmake-build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "run-gateway (full config)",
            "type": "shell",
            "command": "${workspaceFolder}/build/src/service_broker/service_gateway_http",
            "args": [
                "8080",
                "3001",
                "/tmp/service_gateway.sock",
                "${workspaceFolder}/gateway.log",
                "${workspaceFolder}/routes.json",
                "${workspaceFolder}/gateway_config.json"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "cmake-build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "run-auth-service",
            "type": "shell",
            "command": "${workspaceFolder}/build/bin/auth_service",
            "args": [
                "auth_001",
                "localhost",
                "unix:///tmp/rdws_gateway.sock"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "JWT_SECRET": "meu-segredo-dev"
                }
            },
            "dependsOn": "cmake-build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "isBackground": true,
            "problemMatcher": []
        },
