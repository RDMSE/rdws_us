        {
            "label": "run-tests",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--output-on-failure",
                "--parallel"
            ],
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "dependsOn": "cmake-build",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
