        {
            "label": "run-all-services",
            "dependsOn": [
                "run-auth-service",
                "run-farm-service",
                "run-field-service",
                "run-device-service",
                "run-device-config-service",
                "run-sensor-service",
                "run-sensor-reading-service",
                "run-persistence-service"
