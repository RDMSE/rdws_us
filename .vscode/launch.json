{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Gateway HTTP",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/service_broker/service_gateway_http",
            "args": [
                "8085",
                "3001",
                "/tmp/rdws_gateway.sock"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cmake-build"
        },
        {
            "name": "Example Service (inst_001)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/example_service",
            "args": [
                "inst_001",
                "localhost",
                "unix:///tmp/rdws_gateway.sock"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Example Service (inst_002)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/example_service",
            "args": [
                "inst_002",
                "localhost",
                "unix:///tmp/rdws_gateway.sock"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Example Service (--dev)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/example_service",
            "args": ["--dev"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ],
    "compounds": [
        {
            "name": "Gateway + 2 Services",
            "configurations": [
                "Gateway HTTP",
                "Example Service (inst_001)",
                "Example Service (inst_002)"
            ],
            "stopAll": true
        },
        {
            "name": "Gateway + 1 Service",
            "configurations": [
                "Gateway HTTP",
                "Example Service (inst_001)"
            ],
            "stopAll": true
        }
    ]
}
