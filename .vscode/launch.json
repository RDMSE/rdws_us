{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Gateway HTTP",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/service_broker/service_gateway_http",
            "args": [
                "8085",
                "3001",
                "/tmp/rdws_gateway.sock"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cmake-build"
        },
