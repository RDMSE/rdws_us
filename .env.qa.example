# Template para .env.qa (não versionado) — copiar e preencher no homelab.
# Usado por: docker compose -f docker-compose.qa.yml --env-file .env.qa up -d

RDWS_JWT_SECRET=mamae
RDWS_JWT_ISSUER=rdws
RDWS_JWT_AUDIENCE=
RDWS_AUTH_MODE=jwt

# Banco rdws_qa (container postgis/postgis, isolado do rdws_dev)
DB_USER=rdws_user
DB_PASSWORD=password
DB_NAME=rdws_qa

# Chave mestra AES-256 (32 bytes) para criptografar PSKs de device em repouso
# (device_credentials.psk_key_enc) — ver Plano_DeviceCredentials.md. Gerar com:
# openssl rand -base64 32 | cut -c1-32 (ou qualquer string de exatos 32 bytes).
CREDENTIAL_ENCRYPTION_KEY=YwkjFMOSiU1kQkr/dbT9ESh/X4MZjZHm

# RabbitMQ (docker-compose.qa-mq.yml) — fila sensor_readings (Plano_Ingestion.md).
RABBITMQ_USER=rdws_user
RABBITMQ_PASSWORD=password_RabbitMQ

